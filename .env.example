# API Keys and Environment Variables
# Copy this file to .env and fill in your actual values

# OpenAI API (for summarization - optional if using Gemini)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API (FREE - for article summarization)
# Get your free API key at: https://ai.google.dev/
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth (for Gmail/Sheets/Slides)
# Note: credentials.json and token.json are separate OAuth files

# NewsAPI.org (for TechCrunch)
NEWSAPI_ORG_KEY=f7191e1a9d5b467abd7b67178eaca96b

# Z Potentials Substack URL
Z_POTENTIALS_URL=https://zpotentials.substack.com

# Anthropic Claude API (for consumer news summarization + AI news summarization/translation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Add other API keys as needed
# SERPER_API_KEY=your_serper_key_here
